**/.circleci
**/.editorconfig
**/.dockerignore
**/.git
**/.DS_Store
**/.vscode
**/node_modules

# Specific patterns to ignore
data-node
meili_data*
librechat*
!librechat.yaml
Dockerfile*
docs

# Ignore all hidden files
.*

# Env files anywhere in the tree (root .env is covered by .* above; these cover subdirs)
**/.env
**/.env.*
!**/.env.example
!**/.env.test.example
